# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:4200

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/finance_collection?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed admin (used only by `npm run seed`)
SEED_ADMIN_NAME=System Admin
SEED_ADMIN_EMAIL=admin@financecollection.local
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_MOBILE=9999999999

# Email provider (stubbed in Phase 1 - logs instead of sending)
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@financecollection.local

# Password reset
RESET_PASSWORD_TOKEN_EXPIRES_IN=15m
