{
    "version": "0.2.0",
    "configurations": [
        {
            "command": "npm start",
            "name": "Run npm run dev",
            "request": "launch",
            "type": "node-terminal",
             "cwd": "${workspaceFolder}\\backend"
        },

        {
            "name": "Attach",
            "port": 30001,
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\api.js"
        }
    ]
}